{
  "rewrites": [
    {
      "source": "/api/market-:path*",
      "destination": "/api/market-:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://hedera-nft-toolkit-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}

